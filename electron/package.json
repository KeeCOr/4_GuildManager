{
  "name": "guild-manager",
  "version": "1.1.86",
  "description": "용병단 길드 관리 게임",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.stoic.guildmanager",
    "productName": "길드 매니저",
    "copyright": "Copyright © 2026 Stoic Entertainment",
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "GuildManager_v${version}_portable.exe"
    },
    "files": [
      "main.js",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0"
  }
}
